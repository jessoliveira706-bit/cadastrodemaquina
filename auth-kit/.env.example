# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=48h

# LDAP / Active Directory
LDAP_URL=ldaps://host:636
LDAP_BASE_DN=DC=example,DC=local
LDAP_BIND_DN=DOMAIN\service-account
LDAP_BIND_PASSWORD=secret
LDAP_TLS_REJECT_UNAUTHORIZED=false
LDAP_REQUIRED_GROUP=
LDAP_FISCAL_GROUP=Fiscal
LDAP_ADMIN_GROUP=

# Admin emergency login (skips LDAP)
ADMIN_USER=admin
ADMIN_PASSWORD=

# External API keys (comma-separated)
EXTERNAL_API_KEYS=

# Dev bypass token (ignored when NODE_ENV=production)
DEV_TOKEN=dev-token
