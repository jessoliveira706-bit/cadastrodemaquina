# Copie para .env e ajuste os valores (NÃO comite o .env).

# JWT (HS256). Use uma string longa e aleatória em produção.
JWT_SECRET=troque-isto-por-uma-chave-bem-grande-e-aleatoria
JWT_EXPIRES_IN=48h

# Admin de emergência (pula o banco). Login funciona mesmo sem dados.
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# Banco (preenchido pelo docker-compose; ajuste se rodar fora do Docker).
DB_NAME=inventario
DB_USER=inventario
DB_PASSWORD=inventario

# Token de bypass em dev (ignorado quando NODE_ENV=production).
DEV_TOKEN=dev-token

# Origens permitidas para CORS (vazio = não envia headers de CORS;
# desnecessário quando a própria API serve o frontend).
CORS_ORIGIN=
