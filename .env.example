# Copie para .env e ajuste os valores (NÃO comite o .env).

# JWT (HS256). Use uma string longa e aleatória em produção.
JWT_SECRET=troque-isto-por-uma-chave-bem-grande-e-aleatoria
JWT_EXPIRES_IN=48h

# Admin de emergência (pula o banco). Login funciona mesmo sem dados.
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# Banco (usado pelo docker-compose; ajuste se rodar fora do Docker).
DB_NAME=inventario
DB_USER=inventario
DB_PASSWORD=inventario

# Token de bypass em dev (ignorado quando NODE_ENV=production).
DEV_TOKEN=dev-token

# Origens permitidas para CORS (vazio = não envia headers de CORS;
# desnecessário quando a própria API serve o frontend).
CORS_ORIGIN=

# ----------------------------------------------------------------------------
# LDAP / Active Directory
# Se LDAP_URL e LDAP_BASE_DN estiverem definidos, o LDAP passa a ser o provedor
# de login para usuários NÃO-admin (o admin-fallback acima continua valendo).
# Bind direto como LDAP_DOMAIN\usuario. Para usar conta de serviço (fluxo
# search-then-bind do auth-kit), defina LDAP_BIND_DN e LDAP_BIND_PASSWORD.
# ----------------------------------------------------------------------------
LDAP_URL=ldaps://172.16.6.120:636
LDAP_BASE_DN=DC=administracao,DC=franciscomorato,DC=sp,DC=gov,DC=br
LDAP_DOMAIN=ADMINISTRACAO
# TLS: "false" somente em ambientes de dev sem certificado válido
LDAP_TLS_REJECT_UNAUTHORIZED=false
# grupo mínimo para acessar o sistema
LDAP_Cadastro_GROUP=Informatica
# Opcional — conta de serviço (alternativa ao bind por domínio):
# LDAP_BIND_DN=
# LDAP_BIND_PASSWORD=


